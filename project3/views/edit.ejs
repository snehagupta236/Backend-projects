<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <script src="https://cdn.tailwindcss.com"></script>
  <title>Document</title>
</head>
<body>
  <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
    <div class="w-full flex justify-end">
      <a  class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">logout</a>
    </div>
   
    
    <h5 class="mb-5">edit your post</h5>
    <form method="post" action="/update/<%= post._id %>">
      <textarea placeholder="what's on your mind ?" class=" p-3 w-1/3 outline-none resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content" ><%= post.content %></textarea>
      <input class="px-3 w-40 py-2  text-sm bg-yellow-500 text-black block rounded-md mt-2" type="submit" value="update post">
    </form>
    
    
  </div>
</body>
</html>